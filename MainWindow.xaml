<Window x:Class="DoscarVgaDriver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración" Width="340" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Background="#E2E4D2"
        ResizeMode="CanMinimize ">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <SolidColorBrush x:Key="Surface" Color="#E2E4D2"/>
        <SolidColorBrush x:Key="Accent" Color="#7BA7AF"/>
        <SolidColorBrush x:Key="AccentDark" Color="#455957"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentDark}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource AccentDark}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Foreground" Value="{StaticResource AccentDark}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Foreground" Value="{StaticResource AccentDark}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <StackPanel Margin="15">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Conexión" FontSize="14" Foreground="{StaticResource Accent}" Margin="0,0,0,6"/>
                <TextBlock Text="Puerto COM"/>
                <ComboBox x:Name="CmbComPort" IsEditable="True" Margin="0,2,0,10"/>

                <TextBlock Text="Velocidad (baudios)"/>
                <ComboBox x:Name="CmbBaudios" Margin="0,2,0,10"/>

                <TextBlock Text="Monitor"/>
                <ComboBox x:Name="CmbMonitor" Margin="0,2,0,10"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Pantalla" FontSize="14" Foreground="{StaticResource Accent}" Margin="0,0,0,6"/>
                <TextBlock Text="Mensaje de bienvenida"/>
                <TextBox x:Name="TxtHeader" Margin="0,2,0,10"/>

                <TextBlock Text="Símbolo de moneda"/>
                <TextBox x:Name="TxtCurrency" Margin="0,2,0,10"/>

                <CheckBox x:Name="ChkStartFullScreen" Content="Iniciar en pantalla completa" Margin="0,4,0,10"/>

                <CheckBox x:Name="ChkFullScreen" Content="Pantalla completa" Margin="0,0,0,10"
                          Click="FullScreen_Toggle"/>
            </StackPanel>
        </Grid>

        <Separator Margin="0,5,0,10"/>
        <CheckBox x:Name="ChkDevMode" Content="Modo desarrollador" Margin="0,0,0,10"/>

        <StackPanel Visibility="{Binding IsChecked, ElementName=ChkDevMode, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Paridad"/>
            <ComboBox x:Name="CmbParity" Margin="0,2,0,10"/>

            <TextBlock Text="Codificación"/>
            <ComboBox x:Name="CmbEncoding" Margin="0,2,0,10"/>

            <TextBlock Text="Palabra clave Total"/>
            <TextBox x:Name="TxtTotalKeyword" Margin="0,2,0,10"/>

            <TextBlock Text="Palabra clave Inicio"/>
            <TextBox x:Name="TxtIdleKeyword" Margin="0,2,0,10"/>

            <CheckBox x:Name="ChkDebugLog" Content="Registro de depuración (hex)" Margin="0,0,0,10"
                      Click="DebugLog_Toggle"/>
        </StackPanel>

        <TextBlock x:Name="TxtStatus" Margin="0,4,0,8" FontWeight="SemiBold" Text="● Desconectado"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Guardar" Width="80" Margin="0,0,8,0" Click="Save_Click"/>
            <Button Content="Reiniciar Pantalla" Width="120" IsDefault="True" Click="Visor_Restart"/>
        </StackPanel>
    </StackPanel>
</Window>
